generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STUDENT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum StudentStatus {
  ACTIVE
  INACTIVE
}

model User {
  id              String    @id @default(uuid())
  registrationNumber String? @unique
  fullName        String
  email           String    @unique
  phone           String?
  password        String
  role            Role      @default(STUDENT)
  isActive        Boolean   @default(false)
  isEmailVerified Boolean   @default(false)
  status          StudentStatus @default(INACTIVE)
  linkedinProfile String?
  education       String?
  experience      String?
  keySkills       String[]
  jobRole         String?
  assignedTechnologyId String?
  assignedTechnology   AvailableTechnology? @relation("StudentAssignedTechnology", fields: [assignedTechnologyId], references: [id], onDelete: SetNull)
  location        String?
  resumeUrl       String?
  parsedResumeText String?
  department      String?
  avatarUrl       String?
  passportUrl     String?
  drivingLicenceUrl String?
  visaUrl         String?
  googleId        String?   @unique
  profileCompleted Boolean   @default(false)

  // Subscription
  subscriptionPlan   String?
  subscriptionStatus String?
  subscriptionStart  DateTime?
  subscriptionEnd    DateTime?
  stripeSessionId    String?

  // Mentor-specific
  mentorBio       String?
  assignedMentorId String?
  assignedMentor  User?     @relation("MentorStudents", fields: [assignedMentorId], references: [id])
  assignedStudents User[]   @relation("MentorStudents")

  // Relations
  mentoringSlots    MentoringSlot[]    @relation("MentorSlots")
  bookings          MentorBooking[]    @relation("StudentBookings")
  sentMessages      ChatMessage[]      @relation("SentMessages")
  receivedMessages  ChatMessage[]      @relation("ReceivedMessages")
  notifications     Notification[]
  chatGroups        ChatGroup[]        @relation("GroupStudent")
  groupMemberships  ChatGroupMember[]  @relation("GroupMemberships")
  groupMessagesSent GroupMessage[]     @relation("GroupMessagesSent")
  trainingNotes     TrainingNote[]
  successStories    SuccessStory[]
  shoutPosts        ShoutPost[]
  shoutComments     ShoutComment[]
  shoutLikes        ShoutLike[]
  supportQueries    SupportQuery[]   @relation("QueryCreator")
  assignedQueries   SupportQuery[]   @relation("QueryAssignee")
  adminRequestsCreated  AdminRequest[] @relation("AdminRequestsCreated")
  adminRequestsReviewed AdminRequest[] @relation("AdminRequestsReviewed")
  trainingAssignments TrainingAssignment[]
  uploadedMaterials   TrainingMaterial[] @relation("MaterialUploader")
  adminAssignments    StudentAdminAssignment[] @relation("StudentAssignments")
  adminOfStudents     StudentAdminAssignment[] @relation("AdminAssignments")
  jobListings         UserJobListing[] @relation("UserJobListings")
  appliedJobListings  UserJobListing[] @relation("UserAppliedJobListings")
  yourJobs            UserYourJob[]
  jobApplications     UserJobApplication[] @relation("UserJobApplications")
  appliedJobApplications UserJobApplication[] @relation("UserJobApplicationsAppliedBy")

  // Tokens
  verificationToken       String?
  verificationTokenExpiry DateTime?
  resetPasswordToken      String?
  resetPasswordExpiry     DateTime?
  refreshToken            String?
  loginOtp                String?
  loginOtpExpiry          DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([assignedTechnologyId])
  @@map("users")
}

model StudentAdminAssignment {
  id         String   @id @default(uuid())
  studentId  String
  adminId    String
  department String?
  student    User     @relation("StudentAssignments", fields: [studentId], references: [id], onDelete: Cascade)
  admin      User     @relation("AdminAssignments", fields: [adminId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([studentId, adminId])
  @@map("student_admin_assignments")
}

model AvailableTechnology {
  id             String   @id @default(uuid())
  name           String
  normalizedName String   @unique
  category       String
  sortOrder      Int      @default(0)
  content        String   @default("")
  assignedStudents User[] @relation("StudentAssignedTechnology")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category, sortOrder])
  @@map("available_technologies")
}

model MentoringSlot {
  id              String          @id @default(uuid())
  mentorId        String
  startTime       DateTime
  endTime         DateTime
  isBooked        Boolean         @default(false)

  mentor          User            @relation("MentorSlots", fields: [mentorId], references: [id], onDelete: Cascade)
  booking         MentorBooking?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("mentoring_slots")
}

model MentorBooking {
  id              String        @id @default(uuid())
  slotId          String        @unique
  studentId       String
  status          BookingStatus @default(PENDING)
  meetLink        String?
  notes           String?

  slot            MentoringSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  student         User          @relation("StudentBookings", fields: [studentId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("mentor_bookings")
}

model ChatMessage {
  id              String    @id @default(uuid())
  senderId        String
  receiverId      String
  message         String
  isRead          Boolean   @default(false)

  sender          User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver        User      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())

  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, isRead, senderId])
  @@map("chat_messages")
}

model ChatGroup {
  id          String             @id @default(uuid())
  name        String
  studentId   String
  student     User               @relation("GroupStudent", fields: [studentId], references: [id], onDelete: Cascade)
  members     ChatGroupMember[]
  messages    GroupMessage[]

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([studentId])
  @@map("chat_groups")
}

model ChatGroupMember {
  id        String    @id @default(uuid())
  groupId   String
  userId    String

  group     ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation("GroupMemberships", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())

  @@unique([groupId, userId])
  @@map("chat_group_members")
}

model GroupMessage {
  id        String    @id @default(uuid())
  groupId   String
  senderId  String
  message   String
  isRead    Boolean   @default(false)

  group     ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User      @relation("GroupMessagesSent", fields: [senderId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())

  @@map("group_messages")
}

model TrainingMaterial {
  id              String    @id @default(uuid())
  title           String
  description     String?
  type            String    // video, pdf, document, link
  url             String?
  content         String?
  category        String?
  isPublished     Boolean   @default(true)
  uploadedById    String?

  uploadedBy      User?     @relation("MaterialUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  assignments     TrainingAssignment[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("training_materials")
}

model TrainingAssignment {
  id              String    @id @default(uuid())
  materialId      String
  studentId       String

  material        TrainingMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  student         User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  assignedAt      DateTime  @default(now())

  @@unique([materialId, studentId])
  @@map("training_assignments")
}

model TrainingNote {
  id              String    @id @default(uuid())
  userId          String
  title           String
  content         String
  category        String?

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("training_notes")
}

model Notification {
  id              String    @id @default(uuid())
  userId          String
  title           String
  message         String
  type            String
  isRead          Boolean   @default(false)
  link            String?

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, isRead])
  @@map("notifications")
}

model SuccessStory {
  id              String    @id @default(uuid())
  userId          String
  jobTitle        String
  company         String
  story           String
  imageUrl        String?
  isApproved      Boolean   @default(true)

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("success_stories")
}

model ShoutPost {
  id        String         @id @default(uuid())
  userId    String
  content   String
  tag       String?

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  ShoutComment[]
  likes     ShoutLike[]

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("shout_posts")
}

model ShoutComment {
  id        String        @id @default(uuid())
  postId    String
  userId    String
  content   String
  parentId  String?

  post      ShoutPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    ShoutComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   ShoutComment[] @relation("CommentReplies")

  createdAt DateTime      @default(now())

  @@map("shout_comments")
}

model ShoutLike {
  id        String    @id @default(uuid())
  postId    String
  userId    String

  post      ShoutPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())

  @@unique([postId, userId])
  @@map("shout_likes")
}

model SupportQuery {
  id            String   @id @default(uuid())
  userId        String
  assignedToId  String?
  subject       String
  description   String
  category      String   @default("General")
  status        String   @default("OPEN")
  adminReply    String?

  user          User     @relation("QueryCreator", fields: [userId], references: [id], onDelete: Cascade)
  assignedTo    User?    @relation("QueryAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("support_queries")
}

model AdminRequest {
  id                 String   @id @default(uuid())
  adminId            String
  reviewedById       String?
  title              String
  studentFullName    String
  registrationNumber String
  technology         String
  status             String   @default("REQUEST_SENT")
  reviewedAt         DateTime?

  admin              User     @relation("AdminRequestsCreated", fields: [adminId], references: [id], onDelete: Cascade)
  reviewedBy         User?    @relation("AdminRequestsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([adminId, createdAt])
  @@index([status, createdAt])
  @@map("admin_requests")
}

model UserJobListing {
  id             String   @id @default(uuid())
  userId         String
  sourceJobId    String?
  title          String
  company        String
  location       String?
  datePostedText String?
  postedAt       DateTime?
  applyLink      String
  source         String   @default("JSEARCH")
  rawPayload     Json?
  isApplied      Boolean  @default(false)
  appliedAt      DateTime?
  appliedById    String?
  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation("UserJobListings", fields: [userId], references: [id], onDelete: Cascade)
  appliedBy      User?    @relation("UserAppliedJobListings", fields: [appliedById], references: [id], onDelete: SetNull)
  yourJob        UserYourJob?
  applications   UserJobApplication[]

  @@unique([userId, applyLink])
  @@index([userId, lastSeenAt])
  @@index([userId, isApplied, appliedAt])
  @@map("user_job_listings")
}

model UserYourJob {
  id             String   @id @default(uuid())
  userId         String
  sourceListingId String  @unique
  sourceJobId    String?
  title          String
  company        String
  location       String?
  datePostedText String?
  postedAt       DateTime?
  applyLink      String
  source         String   @default("JSEARCH")
  rawPayload     Json?
  matchingScore  Int
  matchLabel     String
  matchProvider  String   @default("fallback")
  matchModel     String?
  matchSummary   String?
  matchWarning   String?
  matchBreakdown Json?
  strongMatches  Json?
  missingSkills  Json?
  matchedAt      DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceListing  UserJobListing @relation(fields: [sourceListingId], references: [id], onDelete: Cascade)
  application    UserJobApplication?

  @@unique([userId, applyLink])
  @@index([userId, matchingScore, updatedAt])
  @@map("user_your_jobs")
}

model UserJobApplication {
  id              String   @id @default(uuid())
  userId          String
  yourJobId       String?  @unique
  sourceListingId String?
  sourceJobId     String?
  title           String
  company         String
  location        String?
  datePostedText  String?
  postedAt        DateTime?
  applyLink       String
  source          String   @default("JSEARCH")
  rawPayload      Json?
  matchingScore   Int?
  matchLabel      String?
  matchProvider   String?
  matchModel      String?
  matchSummary    String?
  matchWarning    String?
  matchBreakdown  Json?
  strongMatches   Json?
  missingSkills   Json?
  status          String   @default("student applied")
  appliedAt       DateTime @default(now())
  appliedById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User            @relation("UserJobApplications", fields: [userId], references: [id], onDelete: Cascade)
  appliedBy       User?           @relation("UserJobApplicationsAppliedBy", fields: [appliedById], references: [id], onDelete: SetNull)
  yourJob         UserYourJob?     @relation(fields: [yourJobId], references: [id], onDelete: SetNull)
  sourceListing   UserJobListing?  @relation(fields: [sourceListingId], references: [id], onDelete: SetNull)

  @@unique([userId, applyLink])
  @@index([userId, appliedAt])
  @@index([userId, status, appliedAt])
  @@map("user_job_applications")
}
