# Environment Variables
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/innogarage?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Email (Gmail SMTP or OAuth2)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="INNOGARAGE.ai <noreply@innogarage.ai>"

# Google OAuth2 for Email (recommended over App Password)
# Get a refresh token from https://developers.google.com/oauthplayground
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Frontend URL
FRONTEND_URL=http://localhost:5173

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Super Admin Default Credentials
SUPER_ADMIN_EMAIL=rapetisaikumar7@gmail.com
SUPER_ADMIN_PASSWORD=Saikumar273@
SUPER_ADMIN_NAME=Super Admin
